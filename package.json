{
  "name": "nks-bob-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:frontend": "MILJO=local vite",
    "dev:server": "pnpm run --filter server dev",
    "dev": "pnpm run \"/^dev:(frontend|server)$/\"",
    "localnais:frontend": "MILJO=localnais vite --host",
    "localnais:server": "MILJO=localnais pnpm run --filter server dev",
    "localnais": "pnpm run \"/^localnais:(frontend|server)$/\"",
    "build:frontend": "tsc -b && vite build",
    "build:server": "pnpm run --filter server build",
    "build": "pnpm run \"/^build:(frontend|server)$/\"",
    "lint": "eslint .",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "preinstall": "npx only-allow pnpm"
  },
  "dependencies": {
    "@navikt/aksel-icons": "^8.13.0",
    "@navikt/ds-css": "^8.13.0",
    "@navikt/ds-react": "^8.13.0",
    "@navikt/ds-tailwind": "^8.13.0",
    "@unhead/react": "^3.1.4",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "mdast-util-find-and-replace": "^3.0.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-error-boundary": "^6.1.2",
    "react-hotkeys-hook": "^5.3.2",
    "react-markdown": "^10.1.0",
    "react-router": "^7.18.0",
    "rehype-raw": "^7.0.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-rehype": "^11.1.2",
    "remark-stringify": "^11.0.0",
    "strip-markdown": "^6.0.0",
    "swr": "^2.4.1",
    "ts-debounce": "^5.0.1",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.1",
    "terser": "^5.48.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16"
  }
}